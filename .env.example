# ══════════════════════════════════════════════════════════════════
# Job Search API — переменные окружения
# Скопируйте в .env и заполните значения
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────
# Neon: postgresql://user:pass@ep-xxx.neon.tech/db?sslmode=require
# Docker: postgresql://jobuser:jobpass@postgres:5432/jobsearch
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── API авторизация ───────────────────────────────────────────────
# Bearer токен для всех защищённых эндпоинтов
API_TOKEN=job-search-token-2026

# ── Redis (опционально) ────────────────────────────────────────────
# Если не задан — /stats работает без кэша (degraded mode)
# Railway: добавить Redis плагин → переменная REDIS_URL появится автоматически
REDIS_URL=redis://localhost:6379/0

# ── Telegram бот ──────────────────────────────────────────────────
# Получить токен: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ID чата: написать боту, открыть api.telegram.org/botTOKEN/getUpdates
TELEGRAM_CHAT_ID=123456789

# ── Планировщик ───────────────────────────────────────────────────
# Время запуска morning_brief.py в UTC (HH:MM)
# 05:15 UTC = 08:15 Алматы (UTC+3) = 08:15 Москва (UTC+3)
SCHEDULER_BRIEF_TIME=05:15

# ── Отладка ───────────────────────────────────────────────────────
DEBUG=false
