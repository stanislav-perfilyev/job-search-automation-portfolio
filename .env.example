# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Telegram Bot API token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat/user ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Sheets spreadsheet ID (from the URL: /spreadsheets/d/<ID>/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# For GitHub Actions only — base64-encoded service account JSON:
# cat sheets_key.json | base64 -w 0
# Then add as a GitHub secret named GOOGLE_SERVICE_ACCOUNT_JSON
